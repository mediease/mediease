					"name": "Register Doctor",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"    var jsonData = pm.response.json();",
									"    if (jsonData.data) {",
									"        if (jsonData.data._id) {",
									"            pm.collectionVariables.set(\"doctor_id\", jsonData.data._id);",
									"        }",
									"        if (jsonData.data.medicalLicenseId) {",
									"            pm.collectionVariables.set(\"doctor_license\", jsonData.data.medicalLicenseId);",
									"        }",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							  "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"email\": \"doctor@example.com\",\n  \"password\": \"password123\",\n  \"confirmPassword\": \"password123\",\n  \"role\": \"doctor\",\n  \"nic\": \"123456789V\",\n  \"medicalLicenseId\": \"DOC001\",\n  \"division\": \"Cardiology\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/auth/register",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"auth",
								"register"
							]
						},
						"description": "Register a new doctor. Requires doctorId and division. Status will be 'pending' until admin approval."
					},
					"response": []
				},
