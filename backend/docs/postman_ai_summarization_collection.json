{
  "info": {
    "_postman_id": "ai-summarization-suite-001",
    "name": "AI Summarization Module - Complete Suite",
    "description": "Comprehensive test suite for MediEase AI Summarization Module\n\nEndpoints:\n- Health Check: Verify AI service availability\n- Patient Summary: Generate medical summary using HuggingFace AI\n\nSetup:\n1. Set HUGGINGFACE_API_KEY in backend .env\n2. Import this collection\n3. Set variable: patientPhn = PH00001 (or valid patient PHN)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Setup & Configuration",
      "item": [
        {
          "name": "1.1 Health Check - Verify AI Service",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('AI Service Connected', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.equal(true);",
                  "    pm.expect(jsonData.data.aiService).to.equal('connected');",
                  "});",
                  "",
                  "pm.test('Response has timestamp', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data).to.have.property('timestamp');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/ai/health",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "ai",
                "health"
              ]
            },
            "description": "Check if HuggingFace AI service is available\n\n**Endpoint:** GET /ai/health\n**Auth:** None (Public endpoint)\n**Purpose:** Verify AI service connectivity before generating summaries"
          }
        },
        {
          "name": "1.2 Verify JWT Token Works",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200 or 401', function () {",
                  "    pm.expect([200, 401, 404]).to.include(pm.response.code);",
                  "});",
                  "",
                  "if (pm.response.code === 401) {",
                  "    pm.test('Token is required', function () {",
                  "        var jsonData = pm.response.json();",
                  "        pm.expect(jsonData.message).to.include('Token');",
                  "    });",
                  "} else if (pm.response.code === 200) {",
                  "    pm.test('Token is valid', function () {",
                  "        pm.expect(true).to.equal(true);",
                  "    });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/ai/summary/PH00001",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "ai",
                "summary",
                "PH00001"
              ]
            },
            "description": "Verify that JWT token is working\n\n**Endpoint:** GET /ai/summary/:phn\n**Auth:** Bearer token required\n**Note:** Will fail if patient doesn't exist, but confirms token acceptance"
          }
        }
      ]
    },
    {
      "name": "2. Generate Summaries - Valid Cases",
      "item": [
        {
          "name": "2.1 Generate Summary - Patient with Full History",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has correct structure', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('success');",
                  "    pm.expect(jsonData).to.have.property('message');",
                  "    pm.expect(jsonData).to.have.property('data');",
                  "});",
                  "",
                  "pm.test('Summary data is present', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data).to.have.property('patientPhn');",
                  "    pm.expect(jsonData.data).to.have.property('summary');",
                  "    pm.expect(jsonData.data).to.have.property('generatedAt');",
                  "});",
                  "",
                  "pm.test('Summary is non-empty string', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(typeof jsonData.data.summary).to.equal('string');",
                  "    pm.expect(jsonData.data.summary.length).to.be.greaterThan(0);",
                  "});",
                  "",
                  "pm.test('Summary contains clinical information', function () {",
                  "    var jsonData = pm.response.json();",
                  "    var summary = jsonData.data.summary.toLowerCase();",
                  "    pm.expect(summary).to.not.be.empty;",
                  "});",
                  "",
                  "pm.test('No PII in summary', function () {",
                  "    var jsonData = pm.response.json();",
                  "    var summary = jsonData.data.summary;",
                  "    pm.expect(summary).to.not.include('PH');",
                  "    pm.expect(summary).to.not.include('@');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/ai/summary/{{patientPhn}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "ai",
                "summary",
                "{{patientPhn}}"
              ]
            },
            "description": "Generate medical summary for patient with full medical history\n\n**Endpoint:** GET /ai/summary/:phn\n**Auth:** Bearer token (doctor/nurse/admin)\n**Expected:** 200 with AI-generated summary\n**Variable:** patientPhn (set to valid patient PHN)\n\nTests verify:\n- Response structure correct\n- Summary content present\n- No PII exposed\n- Timestamp included"
          }
        },
        {
          "name": "2.2 Generate Summary - Patient with Minimal Data",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Handles minimal data gracefully', function () {",
                  "    var jsonData = pm.response.json();",
                  "    if (jsonData.data.summary) {",
                  "        pm.expect(jsonData.data.summary).to.not.be.empty;",
                  "    } else {",
                  "        pm.expect(jsonData.message).to.include('No medical data');",
                  "    }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/ai/summary/PH00002",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "ai",
                "summary",
                "PH00002"
              ]
            },
            "description": "Generate summary for patient with minimal medical records\n\n**Endpoint:** GET /ai/summary/:phn\n**Auth:** Bearer token\n**Expected:** 200 with summary or message about limited data\n\nTests verify:\n- Graceful handling of minimal data\n- No errors with sparse records"
          }
        },
        {
          "name": "2.3 Generate Summary - Different Patient",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200 or 404', function () {",
                  "    pm.expect([200, 404]).to.include(pm.response.code);",
                  "});",
                  "",
                  "if (pm.response.code === 200) {",
                  "    pm.test('Summary generated successfully', function () {",
                  "        var jsonData = pm.response.json();",
                  "        pm.expect(jsonData.data).to.have.property('summary');",
                  "    });",
                  "} else if (pm.response.code === 404) {",
                  "    pm.test('Patient not found', function () {",
                  "        var jsonData = pm.response.json();",
                  "        pm.expect(jsonData.message).to.include('not found');",
                  "    });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/ai/summary/PH00003",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "ai",
                "summary",
                "PH00003"
              ]
            },
            "description": "Generate summary for another patient\n\n**Endpoint:** GET /ai/summary/:phn\n**Auth:** Bearer token\n**Note:** Modify PH00003 to valid patient PHN for your database"
          }
        }
      ]
    },
