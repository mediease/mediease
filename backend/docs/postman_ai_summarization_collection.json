    {
      "name": "5. Performance & Data Integrity",
      "item": [
        {
          "name": "5.1 Response Time Check",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response time is acceptable', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(15000);",
                  "});",
                  "",
                  "pm.test('Response time logged', function () {",
                  "    console.log('Response Time: ' + pm.response.responseTime + 'ms');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/ai/summary/{{patientPhn}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "ai",
                "summary",
                "{{patientPhn}}"
              ]
            },
            "description": "Verify response time is acceptable\n\n**Endpoint:** GET /ai/summary/:phn\n**Auth:** Bearer token\n**Test:** Response time < 15 seconds (HuggingFace model loading time)"
          }
        },
        {
          "name": "5.2 No PII Exposure Check",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('No sensitive data in response', function () {",
                  "    var jsonData = pm.response.json();",
                  "    var summary = JSON.stringify(jsonData);",
                  "    ",
                  "    // Check for common PII patterns",
                  "    pm.expect(summary).to.not.match(/PH\\d{5}/);",
                  "    pm.expect(summary).to.not.match(/\\d{3}-\\d{2}-\\d{4}/); // SSN format",
                  "    pm.expect(summary).to.not.match(/\\b[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Z|a-z]{2,}\\b/); // Email",
                  "    ",
                  "    console.log('PII check passed');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/ai/summary/{{patientPhn}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "ai",
                "summary",
                "{{patientPhn}}"
              ]
            },
            "description": "Verify no PII is exposed in response\n\n**Endpoint:** GET /ai/summary/:phn\n**Auth:** Bearer token\n**Test:** No PHN, SSN, email patterns in response"
          }
        },
        {
          "name": "5.3 Data Consistency - Multiple Calls",
