						"body": {
							"mode": "raw",
							"raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"email\": \"doctor@example.com\",\n  \"password\": \"password123\",\n  \"confirmPassword\": \"password123\",\n  \"role\": \"doctor\",\n  \"nic\": \"123456789V\",\n  \"doctorId\": \"DOC001\",\n  \"division\": \"Cardiology\"\n}"
