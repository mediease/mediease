		{
			"name": "Validate Prescription - NSAID with Gastritis (Should Warn)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test(\"Response is successful\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.success).to.be.true;",
							"});",
							"",
							"pm.test(\"Has warnings\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.warnings).to.be.an('array');",
							"    pm.expect(jsonData.warnings.length).to.be.above(0);",
							"});",
							"",
							"pm.test(\"Prescription is not safe\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.safe).to.be.false;",
							"});",
							"",
							"pm.test(\"Warning contains expected fields\", function () {",
							"    var jsonData = pm.response.json();",
							"    if (jsonData.warnings.length > 0) {",
							"        var warning = jsonData.warnings[0];",
							"        pm.expect(warning).to.have.property('medicineName');",
							"        pm.expect(warning).to.have.property('drugClass');",
							"        pm.expect(warning).to.have.property('relatedCondition');",
							"        pm.expect(warning).to.have.property('severity');",
							"        pm.expect(warning).to.have.property('message');",
							"    }",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"patientPhn\": \"PH12345\",\n  \"patientConditions\": [\"Gastritis\"],\n  \"currentComplaint\": \"Fever and body aches\",\n  \"medicines\": [\n    {\n      \"name\": \"Ibuprofen 200mg Tablet\",\n      \"rxNormId\": \"197806\",\n      \"dose\": \"1 tablet\",\n      \"frequency\": \"TDS\",\n      \"period\": \"5 days\",\n      \"instructions\": \"After meals\"\n    }\n  ]\n}"
				},
				"url": {
					"raw": "{{base_url}}/ai/validate-prescription",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"ai",
						"validate-prescription"
					]
				},
				"description": "Test case: NSAID (Ibuprofen) prescribed to patient with Gastritis - should generate high severity warning"
			},
			"response": []
		},
